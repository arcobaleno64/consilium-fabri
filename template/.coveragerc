[run]
source = artifacts/scripts
omit =
    artifacts/scripts/test_*.py
    artifacts/scripts/Invoke-*.ps1
    artifacts/scripts/load_env.ps1
    artifacts/scripts/backfill_pdca_labels.py
    artifacts/scripts/classify_existing_tasks.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__
    def main\(
    parser\.add_argument
    parser = argparse
    args = parser\.parse
    return parser\.parse
    return run_prompt_case\(
